			"fields": {
				"title": "Senior Frontend Web Developer - DEAP",
				"companyName": "Digital Energy Advisory Platform (DEAP) · Contract",
				"image": {
					"sys": {
						"type": "Link",
						"linkType": "Asset",
						"id": "6SMh0pnpUevHb19rWDwglt"
					}
				},
				"description": "Engaged as a team member on a short-term contractual basis, contributing to the implementation and delivery of the initial version of a web comparator for Czech gas and electricity suppliers, utilizing user consumption history as a fundamental metric.\n\n__Key Qualifications & Responsibilities__\n* Managing my work priorities, project tasks and workflow with Jira\n* Keeping the source code synchronized with git\n* Implementing application using React (v17) with Typescript, Redux for state management, Formik for handling forms submission, PrimeFaces for reusable UI components\n* Styling with Sass and PrimeFaces\n* Estimating tasks' implementation cost to help project manager plan ahead",
				"startDate": "2023-04-01T12:00+02:00",
				"endDate": "2023-07-31T12:00+00:00",
				"skills": ["Typescript", "Redux", "React"]
			}
		},
