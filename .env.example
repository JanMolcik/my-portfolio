NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Tailscale preview helper defaults
TAILSCALE_PREVIEW_PORT=3000
TAILSCALE_PREVIEW_HOST=127.0.0.1
TAILSCALE_PREVIEW_SLUG_TEMPLATE={{full_slug}}
TAILSCALE_PREVIEW_AUTO_START_NEXT=1
TAILSCALE_PREVIEW_FALLBACK_ON_FUNNEL_DISABLED=1
TAILSCALE_MAP_TIMEOUT_SECONDS=10

# Canonical project variables
STORYBLOK_SPACE_ID=290927119725014
STORYBLOK_ACCESS_TOKEN=<REPLACE_WITH_PUBLISHED_TOKEN>
STORYBLOK_PREVIEW_TOKEN=<REPLACE_WITH_PREVIEW_TOKEN>
STORYBLOK_MANAGEMENT_TOKEN=<OPTIONAL_MANAGEMENT_TOKEN_FOR_PUSH_SCRIPT>
PREVIEW_SECRET=<REPLACE_WITH_RANDOM_SECRET>
STORYBLOK_WEBHOOK_SECRET=<REPLACE_WITH_RANDOM_SECRET>
# Local-only fallback so `/` can render draft `home` when not yet published.
# Keep disabled in production.
STORYBLOK_LOCAL_DRAFT_FALLBACK=1

# Storyblok API options
STORYBLOK_API_BASE_URL=https://api.storyblok.com
STORYBLOK_REGION=eu
# In local dev, force fresh published fetches to avoid sticky CDN/client cache.
STORYBLOK_DEV_FORCE_PUBLISHED_CV=1
# Comma-separated list of allowed iframe parents for visual editor embeds.
STORYBLOK_FRAME_ANCESTORS=https://app.storyblok.com

# Legacy blueprint compatibility (optional)
STORYBLOK_DELIVERY_API_TOKEN=<OPTIONAL_LEGACY_ALIAS>

# Local markdown ticket loop (optional)
RALPH_QUEUE_PATH=artifacts/ralph/task-queue.json
RALPH_VERIFY_CMD=
RALPH_ENGINE=codex
RALPH_AGENT_CMD_TEMPLATE=bash scripts/ralph-agent-runner.sh "{{TASK_PROMPT_FILE}}"
RALPH_PROMPT_TEMPLATE_PATH=docs/spec/RALPH_TASK_PROMPT_TEMPLATE.md
RALPH_REQUIRE_AGENTS_ACK=1
RALPH_AUTO_COMMIT=1
RALPH_GIT_USER_NAME=Ralph Loop Bot
RALPH_GIT_USER_EMAIL=ralph-loop@local
RALPH_CODEX_ARGS=
RALPH_CLAUDE_ARGS=
RALPH_DOCKER_MODE=isolated
RALPH_DOCKER_SANDBOX_ROOT=/tmp/my-portfolio-ralph-workspaces
RALPH_DOCKER_SKIP_BUILD=0
RALPH_DOCKER_SKIP_QUEUE_BUILD=0
RALPH_DOCKER_INSTALL_DEPS=1
RALPH_DOCKER_SYNC_BACK=0
RALPH_DOCKER_USER=
RALPH_DOCKER_NODE_MODULES_VOLUME=
RALPH_DOCKER_PNPM_STORE_VOLUME=
RALPH_DOCKER_SHARE_CLAUDE_AUTH=1
RALPH_DOCKER_CLAUDE_DIR=
RALPH_DOCKER_CLAUDE_STATE_FILE=
RALPH_DOCKER_SHARE_CODEX_AUTH=0
RALPH_DOCKER_CODEX_HOME=
# Overnight orchestrator (Docker-first)
RALPH_ORCH_RUNTIME=docker
RALPH_ORCH_DOCKER_MODE=inplace
RALPH_ORCH_DOCKER_AUTO_BUILD=1
RALPH_ORCH_DOCKER_SKIP_BUILD=1
RALPH_ORCH_DOCKER_INSTALL_DEPS=1
RALPH_ORCH_DOCKER_NODE_MODULES_VOLUME=my-portfolio-ralph-node-modules
RALPH_ORCH_DOCKER_PNPM_STORE_VOLUME=my-portfolio-ralph-pnpm-store
TICKETS_QUEUE_STATUSES=ready,in_progress
