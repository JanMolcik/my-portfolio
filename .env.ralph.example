# Ralph loop runtime env (copy to .env.ralph)

# Shared runner contract
RALPH_AGENT_CMD_TEMPLATE='bash scripts/ralph-agent-runner.sh "{{TASK_PROMPT_FILE}}"'
RALPH_LOOP_ARGS='--once'
RALPH_DOCKER_MODE=inplace
RALPH_DOCKER_SKIP_BUILD=1
RALPH_DOCKER_SKIP_QUEUE_BUILD=1
RALPH_DOCKER_INSTALL_DEPS=0
RALPH_AUTO_COMMIT=1
RALPH_GIT_USER_NAME='Ralph Loop Bot'
RALPH_GIT_USER_EMAIL='ralph-loop@local'

# Avoid interactive corepack prompt in Docker
COREPACK_ENABLE_DOWNLOAD_PROMPT=0

# Host-mounted caches for stable Docker runs
RALPH_DOCKER_NODE_MODULES_VOLUME="${PWD}/node_modules"
# Keep pnpm store outside repo to avoid VCS noise and permission drift.
RALPH_DOCKER_PNPM_STORE_VOLUME="${HOME}/.pnpm-store/my-portfolio"

# Orchestrator runtime defaults (ralph-env.sh maps RALPH_DOCKER_* automatically)
RALPH_ORCH_RUNTIME=docker
RALPH_ORCH_DOCKER_AUTO_BUILD=0

# Default engine profile: Codex (ChatGPT account-compatible)
RALPH_ENGINE=codex
RALPH_CODEX_ARGS='--model gpt-5.4 --dangerously-bypass-approvals-and-sandbox'
RALPH_DOCKER_SHARE_CODEX_AUTH=1
RALPH_DOCKER_CODEX_HOME="${HOME}/.codex"

# Optional Claude profile (enable only when needed)
# RALPH_ENGINE=claude
# RALPH_CLAUDE_ARGS='--model opus --permission-mode bypassPermissions --verbose --no-session-persistence'
# RALPH_DOCKER_SHARE_CLAUDE_AUTH=1
