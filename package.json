{
	"name": "my-portfolio",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@10.19.0",
	"scripts": {
		"dev": "next dev",
		"dev:https": "next dev --experimental-https",
		"build": "next build",
		"start": "next start",
		"lint": "eslint . --max-warnings=0",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"format:check": "biome check .",
		"cq": "pnpm run format && pnpm run lint && pnpm run typecheck",
		"cq:check": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
		"test:spec-consistency": "node scripts/spec-consistency.mjs",
		"test:unit": "vitest run --config vitest.config.ts tests/unit",
		"test:integration": "vitest run --config vitest.config.ts tests/integration",
		"test:contract": "vitest run --config vitest.config.ts tests/contract",
		"test:security": "vitest run --config vitest.config.ts tests/security",
		"test:e2e": "playwright test --config=playwright.config.ts",
		"test:harness": "vitest run --config vitest.config.ts tests/harness",
		"tester-agent:run": "node scripts/tester-agent-run.mjs"
	},
	"dependencies": {
		"@storyblok/react": "^5.4.22",
		"next": "16.1.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@playwright/test": "^1.56.1",
		"@vitest/coverage-v8": "^4.0.0-beta.12",
		"@biomejs/biome": "^2.4.5",
		"@eslint/eslintrc": "^3",
		"@netlify/plugin-nextjs": "^5.15.8",
		"@types/node": "^24.3.0",
		"@types/react": "^19.1.11",
		"@types/react-dom": "^19.1.7",
		"eslint": "^9.26.0",
		"eslint-config-next": "16.1.6",
		"typescript": "^5.9.2",
		"vitest": "^4.0.0-beta.12"
	}
}
