      "font-family": ""JetBrains Mono", "Share Tech Mono", monospace",
      "isolation": "isolate",
      "min-height": "100vh",
      "padding": "88px 40px 80px",
    },
    ".title": {
      "font-size": "clamp(34px, 6vw, 64px)",
      "line-height": "0.98",
      "margin": "0",
    },
  },
  "testId": "terminal-noir-project",
}
`;

