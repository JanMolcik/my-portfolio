      "display": "grid",
      "gap": "24px",
      "grid-template-columns": "minmax(0, 1fr) 280px",
      "padding": "32px",
    },
    ".projectPage::before": {
      "background-image": "linear-gradient(rgb(0 255 65 / 3%) 1px, transparent 1px), linear-gradient(90deg, rgb(0 255 65 / 3%) 1px, transparent 1px)",
      "background-size": "40px 40px",
      "content": """",
      "inset": "0",
